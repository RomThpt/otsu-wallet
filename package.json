{
  "name": "otsu",
  "private": true,
  "scripts": {
    "typecheck": "pnpm -r run typecheck",
    "build": "pnpm -r run build",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "lint": "eslint packages/",
    "format": "prettier --write \"packages/*/src/**/*.{ts,vue}\""
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "prettier": "^3.4.0"
  }
}
