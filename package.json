{
  "name": "otsu",
  "private": true,
  "scripts": {
    "typecheck": "pnpm -r run typecheck",
    "build": "pnpm -r run build",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:components": "vitest run --config packages/extension/vitest.config.ts",
    "lint": "eslint packages/",
    "format": "prettier --write \"packages/*/src/**/*.{ts,vue}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,vue}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "packages/*/src/**/*.{ts,vue}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@otsu/eslint-config": "workspace:*",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.3",
    "happy-dom": "^17.4.4",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
