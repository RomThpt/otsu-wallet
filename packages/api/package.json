{
  "name": "@otsu-wallet/api",
  "version": "0.1.0",
  "description": "JavaScript SDK for interacting with the Otsu Wallet browser extension",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "xrpl",
    "xrp",
    "wallet",
    "browser-extension",
    "web3",
    "blockchain",
    "otsu"
  ],
  "author": "RomThpt",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RomThpt/otsu-wallet.git",
    "directory": "packages/api"
  },
  "bugs": {
    "url": "https://github.com/RomThpt/otsu-wallet/issues"
  },
  "homepage": "https://github.com/RomThpt/otsu-wallet/tree/main/packages/api"
}
