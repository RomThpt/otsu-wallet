{
  "name": "@otsu/extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@fontsource/barlow-condensed": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@otsu/constants": "workspace:*",
    "@otsu/core": "workspace:*",
    "@otsu/types": "workspace:*",
    "buffer": "^6.0.3",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.300",
    "@types/qrcode": "^1.5.6",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "chrome-webstore-upload-cli": "^3.5.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^6.4.1",
    "vite-plugin-web-extension": "^4.5.0",
    "vue-tsc": "^2.2.12",
    "web-ext": "^9.4.0"
  },
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsx scripts/sync-version.ts && vite build",
    "build:chrome": "tsx scripts/sync-version.ts && vite build",
    "build:firefox": "tsx scripts/sync-version.ts && tsx scripts/build-firefox-manifest.ts && BROWSER=firefox vite build",
    "build:all": "pnpm build:chrome && pnpm build:firefox",
    "package:chrome": "pnpm build:chrome && tsx scripts/package.ts chrome",
    "package:firefox": "pnpm build:firefox && tsx scripts/package.ts firefox",
    "typecheck": "vue-tsc --noEmit",
    "web-ext:lint": "web-ext lint --source-dir dist"
  }
}
