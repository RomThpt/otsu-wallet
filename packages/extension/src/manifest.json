{
  "manifest_version": 3,
  "name": "Otsu Wallet",
  "description": "A modern, security-first XRPL browser extension wallet",
  "version": "0.0.1",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png"
    }
  },
  "background": {
    "service_worker": "background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.ts"],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "storage",
    "alarms"
  ],
  "web_accessible_resources": [
    {
      "resources": ["provider/inject.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
