{
  "manifest_version": 3,
  "name": "Otsu Wallet",
  "description": "A modern, security-first XRPL browser extension wallet",
  "version": "0.0.1",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png"
    }
  },
  "background": {
    "scripts": [
      "background/index.ts"
    ],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/index.ts"
      ],
      "run_at": "document_start"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "permissions": [
    "storage",
    "alarms",
    "tabs"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "provider/inject.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "otsu-wallet@otsu.dev",
      "strict_min_version": "109.0"
    }
  }
}
